# Copier ce fichier en .env sur le VPS et remplir les valeurs
# cp .env.docker.example .env

# Clé Laravel — générer avec : php artisan key:generate --show
APP_KEY=base64:REMPLACER_PAR_LA_VRAIE_CLE

# Mot de passe PostgreSQL (choisir quelque chose de fort)
DB_PASSWORD=mot_de_passe_fort_ici

# Email (optionnel — si tu veux utiliser Hermes ou un SMTP externe)
# MAIL_MAILER=smtp
# MAIL_HOST=nom_du_conteneur_hermes
# MAIL_PORT=1025
# MAIL_USERNAME=
# MAIL_PASSWORD=
# MAIL_FROM_ADDRESS=noreply@papyrus.guigeek.tech
